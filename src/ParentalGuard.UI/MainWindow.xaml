<Window x:Class="ParentalGuard.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ParentalGuard.UI"
        mc:Ignorable="d"
        Title="ParentalGuard"
        Width="1260"
        Height="840"
        MinWidth="1020"
        MinHeight="720"
        Background="#0A1118"
        FontFamily="Bahnschrift"
        Loaded="OnWindowLoaded">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBrush" Color="#0A1118" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#0E1822" />
        <SolidColorBrush x:Key="CardBrush" Color="#111C27" />
        <SolidColorBrush x:Key="BorderBrushStrong" Color="#213547" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F5F7FA" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9CB0C4" />
        <SolidColorBrush x:Key="AccentBrush" Color="#3FD0AE" />
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#6BB8FF" />
        <SolidColorBrush x:Key="AccentCoralBrush" Color="#FF7D66" />

        <DropShadowEffect x:Key="CardShadow" BlurRadius="24" ShadowDepth="0" Opacity="0.2" Color="#000000" />
        <CubicEase x:Key="EaseOutCubic" EasingMode="EaseOut" />
        <QuadraticEase x:Key="EaseOutQuad" EasingMode="EaseOut" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Effect" Value="{StaticResource CardShadow}" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="18" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ListCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                        <TranslateTransform Y="0" />
                    </TransformGroup>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#35516A" />
                </Trigger>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                             To="1.015"
                                             Duration="0:0:0.24"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                             To="1.015"
                                             Duration="0:0:0.24"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                             To="-4"
                                             Duration="0:0:0.24"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                             To="1"
                                             Duration="0:0:0.22"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                             To="1"
                                             Duration="0:0:0.22"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                             To="0"
                                             Duration="0:0:0.22"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavButtonChrome" Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavButtonChrome" Property="Background" Value="#153244" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NavButtonChrome" Property="Background" Value="#1E4157" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1.03"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1.03"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RoundedActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentCoralBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionButtonChrome" Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActionButtonChrome" Property="Background" Value="#FF8C77" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ActionButtonChrome" Property="Background" Value="#FF6B54" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1.04"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1.04"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RoundedToggleCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="64" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <Border x:Name="Track"
                                    Background="#142533"
                                    BorderBrush="{StaticResource BorderBrushStrong}"
                                    BorderThickness="1"
                                    CornerRadius="17" />
                            <Border x:Name="Glow"
                                    Margin="4"
                                    Background="#00000000"
                                    CornerRadius="14" />
                            <Ellipse x:Name="Thumb"
                                     Width="24"
                                     Height="24"
                                     Margin="5,0,0,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Fill="#F5F7FA"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                        <TranslateTransform X="0" />
                                    </TransformGroup>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <TextBlock x:Name="ToggleText"
                                       Text="Off"
                                       Margin="0,0,10,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#173F3A" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="#33A991" />
                                <Setter TargetName="Glow" Property="Background" Value="#153A34" />
                                <Setter TargetName="ToggleText" Property="Text" Value="On" />
                                <Setter TargetName="ToggleText" Property="Foreground" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ToggleText" Property="HorizontalAlignment" Value="Left" />
                                <Setter TargetName="ToggleText" Property="Margin" Value="10,0,0,0" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="#3A5F77" />
                            </Trigger>
                            <EventTrigger RoutedEvent="Checked">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.X)"
                                                         To="30"
                                                         Duration="0:0:0.22"
                                                         EasingFunction="{StaticResource EaseOutCubic}" />
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                         From="0.92"
                                                         To="1"
                                                         Duration="0:0:0.22"
                                                         EasingFunction="{StaticResource EaseOutCubic}" />
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                         From="0.92"
                                                         To="1"
                                                         Duration="0:0:0.22"
                                                         EasingFunction="{StaticResource EaseOutCubic}" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Unchecked">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.X)"
                                                         To="0"
                                                         Duration="0:0:0.22"
                                                         EasingFunction="{StaticResource EaseOutCubic}" />
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                         From="0.92"
                                                         To="1"
                                                         Duration="0:0:0.22"
                                                         EasingFunction="{StaticResource EaseOutCubic}" />
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                         From="0.92"
                                                         To="1"
                                                         Duration="0:0:0.22"
                                                         EasingFunction="{StaticResource EaseOutCubic}" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PageBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="{StaticResource SidebarBrush}" BorderBrush="#1A2B3B" BorderThickness="0,0,1,0" Padding="18">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,6">
                    <Border Width="40" Height="40" CornerRadius="12" Background="#173040" Margin="0,0,12,0">
                        <Grid>
                            <Path Data="M12,6 L28,6 L28,16 C28,22 24,28 20,30 C16,28 12,22 12,16 Z" Fill="{StaticResource AccentBrush}" Stretch="Fill" Margin="8" />
                        </Grid>
                    </Border>
                    <TextBlock Text="ParentalGuard" Foreground="{StaticResource TextPrimaryBrush}" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="Live app and website usage" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,24" />

                <Button Style="{StaticResource NavButtonStyle}" Background="{Binding OverviewButtonBrush}" Content="Overview" Click="OnOverviewClick" />
                <Button Style="{StaticResource NavButtonStyle}" Background="{Binding UsageButtonBrush}" Margin="0,8,0,0" Content="Usage" Click="OnUsageClick" />
                <Button Style="{StaticResource NavButtonStyle}" Background="{Binding SettingsButtonBrush}" Margin="0,8,0,0" Content="Settings" Click="OnSettingsClick" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Canvas IsHitTestVisible="False">
                <Ellipse Width="360" Height="360" Canvas.Left="-120" Canvas.Top="-90" Opacity="0.28">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#214666" Offset="0" />
                            <GradientStop Color="#00000000" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
            </Canvas>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="28">
                    <Border x:Name="HeaderCard" Style="{StaticResource CardStyle}" Margin="0,0,0,22">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding PageTitle}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="34" FontWeight="SemiBold" />
                            <Border Grid.Column="1" Padding="16,10" Background="#132532" CornerRadius="14" VerticalAlignment="Top">
                                <TextBlock Text="{Binding CurrentClockText}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Visibility="{Binding OverviewVisibility}">
                        <Border x:Name="GraphCard" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Screen time line graph" Foreground="{StaticResource TextPrimaryBrush}" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Margin="0,8,0,0" Text="Stored in the local database and updated over time." Foreground="{StaticResource TextSecondaryBrush}" />

                                <Grid Margin="0,24,0,0">
                                    <Canvas Height="220">
                                        <Path Stroke="{StaticResource AccentBlueBrush}" StrokeThickness="3" Data="{Binding UsageLineGeometry}" />
                                        <ItemsControl ItemsSource="{Binding DailyUsageGraph}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type local:LineGraphPoint}">
                                                    <Grid>
                                                        <Ellipse Width="12" Height="12" Fill="{StaticResource AccentBrush}" />
                                                        <TextBlock Margin="-18,-28,0,0" Text="{Binding DurationText}" Foreground="{StaticResource TextSecondaryBrush}" />
                                                        <TextBlock Margin="-8,18,0,0" Text="{Binding Label}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Canvas>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Visibility="{Binding UsageVisibility}">
                        <Border x:Name="UsageCombinedCard" Style="{StaticResource CardStyle}" Margin="0,0,0,22">
                            <StackPanel>
                                <TextBlock Text="Usage" Foreground="{StaticResource TextPrimaryBrush}" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Margin="0,8,0,0" Text="All apps and website domains in one list. Each website domain is its own item." Foreground="{StaticResource TextSecondaryBrush}" />

                                <ItemsControl Margin="0,18,0,0" ItemsSource="{Binding AllUsage}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type local:UsageEntry}">
                                            <Border Margin="0,0,0,12" Style="{StaticResource ListCardStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Ellipse Width="10" Height="10" Fill="{Binding AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
                                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="SemiBold" />
                                                        </StackPanel>
                                                        <TextBlock Margin="0,8,0,0" Text="{Binding Subtitle}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Margin="16,0,0,0" Text="{Binding DurationText}" Foreground="{Binding AccentBrush}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Visibility="{Binding SettingsVisibility}">
                        <Border x:Name="SettingsCard" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Block settings" Foreground="{StaticResource TextPrimaryBrush}" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Margin="0,8,0,0" Text="Apps and websites are combined below. New apps and domains are added here automatically when they are used." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />

                                <ItemsControl Margin="0,18,0,0" ItemsSource="{Binding BlockRules}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type local:BlockRule}">
                                            <Border Margin="0,0,0,12" Style="{StaticResource ListCardStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="SemiBold" />
                                                            <Border Margin="10,0,0,0" Padding="8,3" Background="#173040" CornerRadius="10">
                                                                <TextBlock Text="{Binding TargetType}" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="SemiBold" />
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <CheckBox Grid.Column="1"
                                                              Style="{StaticResource RoundedToggleCheckBoxStyle}"
                                                              Margin="18,0,18,0"
                                                              VerticalAlignment="Center"
                                                              IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}" />

                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="Block after" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                        <Border Background="#132532" BorderBrush="{StaticResource BorderBrushStrong}" BorderThickness="1" CornerRadius="12">
                                                            <TextBox Width="64"
                                                                     Text="{Binding MaxMinutes, UpdateSourceTrigger=PropertyChanged}"
                                                                     Padding="10,6"
                                                                     Background="Transparent"
                                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                                     BorderThickness="0"
                                                                     HorizontalContentAlignment="Center" />
                                                        </Border>
                                                        <TextBlock Text="min" Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0,0,0" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Content="Save settings"
                                        Style="{StaticResource RoundedActionButtonStyle}"
                                        Width="140"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Click="OnSaveSettingsClick" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <Border x:Name="BlockPopupHost"
                    Visibility="{Binding BlockPopupVisibility}"
                    Opacity="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,28,28"
                    Padding="16,12"
                    Background="#162734"
                    BorderBrush="{StaticResource AccentCoralBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="0.92" ScaleY="0.92" />
                        <TranslateTransform Y="14" />
                    </TransformGroup>
                </Border.RenderTransform>
                <TextBlock Text="{Binding BlockPopupMessage}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="14"
                           FontWeight="SemiBold" />
            </Border>
        </Grid>
    </Grid>
</Window>
