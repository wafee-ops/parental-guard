<Window x:Class="ParentalGuard.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:WindowChrome="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:ParentalGuard.UI"
        mc:Ignorable="d"
        Title="ParentalGuard"
        Width="1260"
        Height="840"
        MinWidth="1020"
        MinHeight="720"
        Background="Transparent"
        FontFamily="{StaticResource Nunito}"
        Loaded="OnWindowLoaded"
        StateChanged="OnWindowStateChanged"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="38"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="-1"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF051018" Offset="0" />
            <GradientStop Color="#FF0A1824" Offset="0.42" />
            <GradientStop Color="#FF132333" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PageBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#C40A1420" Offset="0" />
            <GradientStop Color="#B20D1A27" Offset="0.5" />
            <GradientStop Color="#B0142433" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="SidebarBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#9A0E1A26" Offset="0" />
            <GradientStop Color="#86111E2B" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CardBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#AA162433" Offset="0" />
            <GradientStop Color="#7E112030" Offset="0.56" />
            <GradientStop Color="#80101B28" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="BorderBrushStrong" Color="#2B4A61" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F4FAFF" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9DB4C8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#71E4C3" />
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#84C8FF" />
        <SolidColorBrush x:Key="AccentCoralBrush" Color="#FF8A72" />
        <SolidColorBrush x:Key="AccentGoldBrush" Color="#FFD58A" />

        <DropShadowEffect x:Key="CardShadow" BlurRadius="42" ShadowDepth="10" Opacity="0.24" Color="#02060B" />
        <DropShadowEffect x:Key="ButtonGlowShadow" BlurRadius="18" ShadowDepth="0" Opacity="0.28" Color="#71E4C3" />
        <CubicEase x:Key="EaseOutCubic" EasingMode="EaseOut" />
        <QuadraticEase x:Key="EaseOutQuad" EasingMode="EaseOut" />
        <BackEase x:Key="EaseOutBack" EasingMode="EaseOut" Amplitude="0.5" />
        <CubicEase x:Key="EaseInOutCubic" EasingMode="EaseInOut" />
        <PowerEase x:Key="EaseOutPower" EasingMode="EaseOut" Power="3" />

        <LinearGradientBrush x:Key="GlassOverlayBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#14FFFFFF" Offset="0" />
            <GradientStop Color="#06FFFFFF" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GlassOverlayStrongBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#26FFFFFF" Offset="0" />
            <GradientStop Color="#0AFFFFFF" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GlassHighlightBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#1AFFFFFF" Offset="0" />
            <GradientStop Color="#00FFFFFF" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="NavButtonBaseBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#1C2733" Offset="0" />
            <GradientStop Color="#121B25" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="TitleButtonBaseBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#1A2330" Offset="0" />
            <GradientStop Color="#111A24" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="TitleButtonHoverBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#243141" Offset="0" />
            <GradientStop Color="#16202B" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="TitleCloseHoverBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#5C302D" Offset="0" />
            <GradientStop Color="#442321" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PrimaryButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF7DFFC4" Offset="0" />
            <GradientStop Color="#FF49D7C1" Offset="0.5" />
            <GradientStop Color="#FF4FA8FF" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="DangerButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFB199" Offset="0" />
            <GradientStop Color="#FFFF8A72" Offset="0.55" />
            <GradientStop Color="#FFFF6F90" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="#44A8C8DB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="28" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Effect" Value="{StaticResource CardShadow}" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" />
                        <TranslateTransform Y="28" />
                    </TransformGroup>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ListCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                        <TranslateTransform Y="0" />
                    </TransformGroup>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#35516A" />
                </Trigger>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                             To="1.015"
                                             Duration="0:0:0.24"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                             To="1.015"
                                             Duration="0:0:0.24"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                             To="-4"
                                             Duration="0:0:0.24"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                             To="1"
                                             Duration="0:0:0.22"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                             To="1"
                                             Duration="0:0:0.22"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                             To="0"
                                             Duration="0:0:0.22"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="18,14" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="NavButtonBase"
                                    Background="{StaticResource NavButtonBaseBrush}"
                                    BorderBrush="#1EFFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="18" />
                            <Border x:Name="NavButtonChrome"
                                    Margin="1"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="17" />
                            <Border x:Name="GlassBorder"
                                    Margin="1"
                                    CornerRadius="17"
                                    BorderBrush="#18FFFFFF" BorderThickness="1"
                                    Background="{StaticResource GlassOverlayBrush}" />
                            <Rectangle x:Name="SelectionGlow"
                                       Width="56"
                                       HorizontalAlignment="Left"
                                       Fill="#00FFFFFF"
                                       RadiusX="18"
                                       RadiusY="18" />
                             <Rectangle x:Name="Shine" RadiusX="16" RadiusY="16"
                                        VerticalAlignment="Top" Height="18" Margin="2,2,2,0"
                                        Opacity="0.85"
                                        Fill="{StaticResource GlassHighlightBrush}" />
                             <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                         </Grid>
                         <ControlTemplate.Triggers>
                             <Trigger Property="IsMouseOver" Value="True">
                                 <Setter TargetName="NavButtonBase" Property="BorderBrush" Value="#34FFFFFF" />
                                 <Setter TargetName="NavButtonChrome" Property="Background" Value="#20394C" />
                                <Setter TargetName="GlassBorder" Property="BorderBrush" Value="#2AFFFFFF" />
                                <Setter TargetName="GlassBorder" Property="Background" Value="{StaticResource GlassOverlayStrongBrush}" />
                                <Setter TargetName="SelectionGlow" Property="Fill" Value="#0CA2D8FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NavButtonChrome" Property="Background" Value="#1A2E3F" />
                                <Setter TargetName="GlassBorder" Property="BorderBrush" Value="#18FFFFFF" />
                                <Setter TargetName="GlassBorder" Property="Background" Value="{StaticResource GlassOverlayBrush}" />
                                <Setter TargetName="SelectionGlow" Property="Fill" Value="#08FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1.015"
                                             Duration="0:0:0.16"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1.015"
                                             Duration="0:0:0.16"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1"
                                             Duration="0:0:0.16"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1"
                                             Duration="0:0:0.16"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RoundedActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#061118" />
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Effect" Value="{StaticResource ButtonGlowShadow}" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="ActionButtonChrome" Background="{TemplateBinding Background}" CornerRadius="18" />
                            <Border x:Name="GlassBorder" CornerRadius="18"
                                    BorderBrush="#50FFFFFF" BorderThickness="1"
                                    Background="#22FFFFFF" />
                             <Rectangle x:Name="Shine" RadiusX="16" RadiusY="16"
                                        VerticalAlignment="Top" Height="18" Margin="1"
                                        Fill="{StaticResource GlassHighlightBrush}" />
                             <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                         </Grid>
                         <ControlTemplate.Triggers>
                             <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="GlassBorder" Property="BorderBrush" Value="#7AFFFFFF" />
                                <Setter TargetName="GlassBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#4DFFFFFF" Offset="0" />
                                            <GradientStop Color="#18FFFFFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="GlassBorder" Property="BorderBrush" Value="#32FFFFFF" />
                                <Setter TargetName="GlassBorder" Property="Background" Value="#10FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1.04"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1.04"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RoundedToggleCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="64" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <Border x:Name="Track"
                                    Background="#142533"
                                    BorderBrush="{StaticResource BorderBrushStrong}"
                                    BorderThickness="1"
                                    CornerRadius="17" />
                            <Border x:Name="Glow"
                                    Margin="4"
                                    Background="#00000000"
                                    CornerRadius="14" />
                            <Ellipse x:Name="Thumb"
                                     Width="24"
                                     Height="24"
                                     Margin="5,0,0,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Fill="#F5F7FA"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                        <TranslateTransform X="0" />
                                    </TransformGroup>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <TextBlock x:Name="ToggleText"
                                       Text="Off"
                                       Margin="0,0,10,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#173F3A" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="#33A991" />
                                <Setter TargetName="Glow" Property="Background" Value="#153A34" />
                                <Setter TargetName="ToggleText" Property="Text" Value="On" />
                                <Setter TargetName="ToggleText" Property="Foreground" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ToggleText" Property="HorizontalAlignment" Value="Left" />
                                <Setter TargetName="ToggleText" Property="Margin" Value="10,0,0,0" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="#3A5F77" />
                            </Trigger>
                            <EventTrigger RoutedEvent="Checked">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.X)"
                                                         To="30"
                                                         Duration="0:0:0.22"
                                                         EasingFunction="{StaticResource EaseOutCubic}" />
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                         From="0.92"
                                                         To="1"
                                                         Duration="0:0:0.22"
                                                         EasingFunction="{StaticResource EaseOutCubic}" />
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                         From="0.92"
                                                         To="1"
                                                         Duration="0:0:0.22"
                                                         EasingFunction="{StaticResource EaseOutCubic}" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Unchecked">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.X)"
                                                         To="0"
                                                         Duration="0:0:0.22"
                                                         EasingFunction="{StaticResource EaseOutCubic}" />
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                         From="0.92"
                                                         To="1"
                                                         Duration="0:0:0.22"
                                                         EasingFunction="{StaticResource EaseOutCubic}" />
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                         From="0.92"
                                                         To="1"
                                                         Duration="0:0:0.22"
                                                         EasingFunction="{StaticResource EaseOutCubic}" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GlassSmallButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" CornerRadius="12"
                                BorderBrush="#26FFFFFF" BorderThickness="1"
                                Background="#18FFFFFF">
                            <Grid>
                                <Rectangle x:Name="Shine" RadiusX="10" RadiusY="10"
                                           VerticalAlignment="Top" Height="14" Margin="1"
                                           Fill="{StaticResource GlassHighlightBrush}" />
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#28FFFFFF" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#40FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#12FFFFFF" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#1AFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1.06" Duration="0:0:0.14"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1.06" Duration="0:0:0.14"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1" Duration="0:0:0.14"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1" Duration="0:0:0.14"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AnimatedTitleBarButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Chrome" CornerRadius="10"
                                    BorderBrush="#1EFFFFFF" BorderThickness="1"
                                    Background="{StaticResource TitleButtonBaseBrush}" />
                            <Rectangle x:Name="Shine" RadiusX="9" RadiusY="9"
                                       VerticalAlignment="Top" Height="10" Margin="1,1,1,0"
                                       Opacity="0.75"
                                       Fill="{StaticResource GlassHighlightBrush}" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,1" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource TitleButtonHoverBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#30FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#101923" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#18FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1.04" Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1.04" Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1" Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1" Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AnimatedCloseButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Chrome" CornerRadius="10"
                                    BorderBrush="#26B76A66" BorderThickness="1"
                                    Background="{StaticResource TitleButtonBaseBrush}" />
                            <Border x:Name="HoverBg" CornerRadius="10"
                                    Background="#00FF7D66" />
                            <Rectangle x:Name="Shine" RadiusX="9" RadiusY="9"
                                       VerticalAlignment="Top" Height="10" Margin="1,1,1,0"
                                       Opacity="0.75"
                                       Fill="{StaticResource GlassHighlightBrush}" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,1" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource TitleCloseHoverBrush}" />
                                <Setter TargetName="HoverBg" Property="Background" Value="#12FF8E84" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#46FF8E84" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#391E1D" />
                                <Setter TargetName="HoverBg" Property="Background" Value="#20FF8E84" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#26FF8E84" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1.04" Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1.04" Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1" Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1" Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border" BasedOn="{StaticResource ListCardStyle}">
            <Setter Property="Padding" Value="24,26" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#8A1A3042" Offset="0" />
                        <GradientStop Color="#7E112231" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#22354B" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#284A64" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkFilterComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#132131" />
            <Setter Property="BorderBrush" Value="#2A445A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,12,40,12" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <Border x:Name="OuterBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="18">
                                <Grid>
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                                    <Path Width="12" Height="8"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Margin="0,0,16,0"
                                          Stroke="{StaticResource TextSecondaryBrush}"
                                          StrokeThickness="2"
                                          Data="M1,1 L6,6 L11,1"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round" />
                                </Grid>
                            </Border>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border Margin="0,8,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="#101B28"
                                        BorderBrush="#33506A"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="8">
                                    <ScrollViewer CanContentScroll="True"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#3C627E" />
                                <Setter TargetName="OuterBorder" Property="Background" Value="#162739" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter Property="MinHeight" Value="44" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassInputBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#1AFFFFFF" />
            <Setter Property="BorderBrush" Value="#2AFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="GlassTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="GlassPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="20" />
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="0" Margin="0"
            Background="{StaticResource WindowBackgroundBrush}" BorderBrush="#1A2B3B" BorderThickness="0">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.ColumnSpan="2" x:Name="TopBar" Background="#330C1823"
                BorderBrush="#14FFFFFF" BorderThickness="0,0,0,1">
            <Grid>
                <Border x:Name="TopBarShimmer" Opacity="0" IsHitTestVisible="False">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop x:Name="ShimmerStop1" Color="#083FD0AE" Offset="0" />
                            <GradientStop x:Name="ShimmerStop2" Color="#003FD0AE" Offset="0.35" />
                            <GradientStop x:Name="ShimmerStop3" Color="#086BB8FF" Offset="0.65" />
                            <GradientStop x:Name="ShimmerStop4" Color="#006BB8FF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <Rectangle x:Name="TopBarAccentLine" VerticalAlignment="Bottom" Height="1"
                           Opacity="0" IsHitTestVisible="False">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#003FD0AE" Offset="0" />
                            <GradientStop Color="#3FD0AE" Offset="0.3" />
                            <GradientStop Color="#6BB8FF" Offset="0.5" />
                            <GradientStop Color="#3FD0AE" Offset="0.7" />
                            <GradientStop Color="#003FD0AE" Offset="1" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <Border x:Name="TopBarLogo" Width="22" Height="22" CornerRadius="6"
                                Background="#173040" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="0" ScaleY="0" />
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect x:Name="LogoGlow" Color="#3FD0AE"
                                                  BlurRadius="14" ShadowDepth="0" Opacity="0" />
                            </Border.Effect>
                            <Path Data="M12,6 L28,6 L28,16 C28,22 24,28 20,30 C16,28 12,22 12,16 Z"
                                  Fill="{StaticResource AccentBrush}" Stretch="Fill" Margin="4" />
                        </Border>

                        <TextBlock x:Name="TopBarTitleText" Text="ParentalGuard"
                                   Foreground="#9CB0C4" FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                   Opacity="0" RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <TranslateTransform X="-10" />
                            </TextBlock.RenderTransform>
                        </TextBlock>

                        <Grid Margin="8,0,0,0" VerticalAlignment="Center"
                              Width="10" Height="10">
                            <Ellipse x:Name="StatusDotGlow" Width="10" Height="10"
                                     Fill="#3FD0AE" Opacity="0.2"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse x:Name="StatusDot" Width="5" Height="5"
                                     Fill="{StaticResource AccentBrush}" Opacity="0.85"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>

                    <Border HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,6,0"
                            Padding="2"
                            CornerRadius="12"
                            BorderBrush="#18FFFFFF"
                            BorderThickness="1"
                            Background="#0E151E">
                    <StackPanel Orientation="Horizontal">
                        <Button Click="OnMinimizeClick"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Style="{StaticResource AnimatedTitleBarButtonStyle}"
                                Width="36" Height="24"
                                Foreground="#9CB0C4">
                            <Grid Width="12" Height="12"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  SnapsToDevicePixels="True">
                                <Rectangle Width="11"
                                           Height="1.2"
                                           RadiusX="0.6"
                                           RadiusY="0.6"
                                           Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                        <Button Click="OnMaximizeClick"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Style="{StaticResource AnimatedTitleBarButtonStyle}"
                                Width="36" Height="24"
                                Margin="2,0,0,0"
                                Foreground="#9CB0C4">
                            <Grid Width="12" Height="12"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  SnapsToDevicePixels="True">
                                <Rectangle Width="8"
                                           Height="8"
                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           StrokeThickness="1"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="1,0,0,0" />
                                <Rectangle Width="8"
                                           Height="8"
                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           StrokeThickness="1"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="-1,2,0,0" />
                            </Grid>
                        </Button>
                        <Button Click="OnCloseClick"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Style="{StaticResource AnimatedCloseButtonStyle}"
                                Width="36" Height="24"
                                Margin="2,0,0,0"
                                Foreground="#FF958C">
                            <Grid Width="12" Height="12"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  SnapsToDevicePixels="True">
                                <Path Data="M2,2 L10,10 M10,2 L2,10"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.4"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                    </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="SidebarBorder" Grid.Row="1" Background="{StaticResource SidebarBrush}" BorderBrush="#22FFFFFF" BorderThickness="0,0,1,0" Padding="20">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,8">
                    <Border Width="46" Height="46" CornerRadius="16" Background="#224865" Margin="0,0,12,0">
                        <Grid>
                            <Path Data="M12,6 L28,6 L28,16 C28,22 24,28 20,30 C16,28 12,22 12,16 Z" Fill="{StaticResource AccentBrush}" Stretch="Fill" Margin="9" />
                        </Grid>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ParentalGuard" Foreground="{StaticResource TextPrimaryBrush}" FontSize="24" FontWeight="SemiBold" />
                        <TextBlock Text="Family shield panel" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                    </StackPanel>
                </StackPanel>
                <Border Margin="0,0,0,22" Padding="14" CornerRadius="18" Background="#12FFFFFF" BorderBrush="#18FFFFFF" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Live app and website usage" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" />
                        <TextBlock Text="Fluid monitoring, quick controls, and a softer glass dashboard." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <Button Style="{StaticResource NavButtonStyle}" Background="{Binding OverviewButtonBrush}" Content="Overview" Click="OnOverviewClick" />
                <Button Style="{StaticResource NavButtonStyle}" Background="{Binding UsageButtonBrush}" Margin="0,8,0,0" Content="Usage" Click="OnUsageClick" />
                <Button Style="{StaticResource NavButtonStyle}" Background="{Binding SettingsButtonBrush}" Margin="0,8,0,0" Content="Settings" Click="OnSettingsClick" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Grid.Column="1">
            <Canvas IsHitTestVisible="False">
                <Ellipse x:Name="AmbientOrbOne" Width="420" Height="420" Canvas.Left="-150" Canvas.Top="-130" Opacity="0.34">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#2B57B5D8" Offset="0" />
                            <GradientStop Color="#00000000" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse x:Name="AmbientOrbTwo" Width="520" Height="520" Canvas.Left="520" Canvas.Top="-120" Opacity="0.28">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#246DE1C8" Offset="0" />
                            <GradientStop Color="#00000000" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse x:Name="AmbientOrbThree" Width="480" Height="480" Canvas.Left="720" Canvas.Top="360" Opacity="0.2">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#28FF9C8B" Offset="0" />
                            <GradientStop Color="#00000000" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
            </Canvas>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="28">
                    <Border x:Name="HeaderCard" Style="{StaticResource CardStyle}" Margin="0,0,0,22">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding PageTitle}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="34" FontWeight="SemiBold" />
                                <TextBlock Text="Quiet glass surfaces, faster feedback, and calmer motion across the whole control panel." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0" />
                            </StackPanel>
                            <Border Grid.Column="1" Padding="18,12" Background="#16FFFFFF" CornerRadius="18" VerticalAlignment="Top" BorderBrush="#24FFFFFF" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding CurrentClockText}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid x:Name="OverviewGrid" Visibility="{Binding OverviewVisibility}">
                        <Border x:Name="GraphCard" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Usage Overview" Foreground="{StaticResource TextPrimaryBrush}" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Margin="0,8,0,0" Text="Screen time summary updated in real time." Foreground="{StaticResource TextSecondaryBrush}" />

                                <Grid Margin="0,28,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Margin="0,0,10,0" Style="{StaticResource MetricCardStyle}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Today" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding TodayTotalText}" Foreground="{StaticResource AccentBrush}" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Margin="10,0,10,0" Style="{StaticResource MetricCardStyle}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Yesterday" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding YesterdayTotalText}" Foreground="{StaticResource AccentBlueBrush}" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Margin="10,0,0,0" Style="{StaticResource MetricCardStyle}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Last 7 Days" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding LastWeekTotalText}" Foreground="{StaticResource AccentCoralBrush}" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="UsageGrid" Visibility="{Binding UsageVisibility}">
                        <Border x:Name="UsageCombinedCard" Style="{StaticResource CardStyle}" Margin="0,0,0,22">
                            <StackPanel>
                                <TextBlock Text="App Usage Stats" Foreground="{StaticResource TextPrimaryBrush}" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Margin="0,8,0,0" Text="A darker usage dashboard with hourly screen-time patterns and ranked activity share." Foreground="{StaticResource TextSecondaryBrush}" />

                                <Grid Margin="0,22,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0"
                                              Margin="0,0,10,0"
                                              ItemsSource="{Binding UsagePeriodOptions}"
                                              SelectedItem="{Binding SelectedUsagePeriod}"
                                              Style="{StaticResource DarkFilterComboBoxStyle}" />
                                    <ComboBox Grid.Column="1"
                                              Margin="10,0,0,0"
                                              ItemsSource="{Binding UsageCategoryOptions}"
                                              SelectedItem="{Binding SelectedUsageCategory}"
                                              Style="{StaticResource DarkFilterComboBoxStyle}" />
                                </Grid>

                                <Border Margin="0,22,0,0"
                                        Padding="26"
                                        CornerRadius="28"
                                        BorderBrush="#30516C"
                                        BorderThickness="1">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#B3172535" Offset="0" />
                                            <GradientStop Color="#A0111C29" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding UsageTotalText}"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontSize="34"
                                                           FontWeight="Bold" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding UsagePeriodTitle}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="20"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="{Binding UsageSummaryText}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <Border Grid.Column="1"
                                                    Padding="14,10"
                                                    CornerRadius="16"
                                                    Background="#163248"
                                                    BorderBrush="#2B5872"
                                                    BorderThickness="1"
                                                    VerticalAlignment="Top">
                                                <StackPanel>
                                                    <TextBlock Text="Hourly peak"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="{Binding UsagePeakHourText}"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <ItemsControl Margin="0,26,0,0" ItemsSource="{Binding HourlyUsageBars}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Rows="1" Columns="24" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type local:HourlyUsageBar}">
                                                    <Grid Height="200" Margin="3,0" ToolTip="{Binding AccessibilityLabel}">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <Border Grid.Row="0"
                                                                VerticalAlignment="Bottom"
                                                                Height="{Binding Height}"
                                                                Background="{Binding FillBrush}"
                                                                CornerRadius="10,10,4,4"
                                                                BorderBrush="#16FFFFFF"
                                                                BorderThickness="1" />
                                                        <TextBlock Grid.Row="1"
                                                                   Margin="0,10,0,0"
                                                                   Text="{Binding Label}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontSize="11"
                                                                   HorizontalAlignment="Center" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Margin="0,10,0,0"
                                                   Text="{Binding UsageChartHintText}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="13" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Margin="0,24,0,14"
                                           Text="Apps &amp; sites"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="22"
                                           FontWeight="SemiBold" />

                                <ItemsControl ItemsSource="{Binding AllUsage}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type local:UsageEntry}">
                                            <Border Margin="0,0,0,14" Style="{StaticResource ListCardStyle}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="46"
                                                                    Height="46"
                                                                    CornerRadius="16"
                                                                    Background="{Binding AccentBrush}">
                                                                <TextBlock Text="{Binding Initial}"
                                                                           Foreground="#FF08121D"
                                                                           FontSize="18"
                                                                           FontWeight="Bold"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center" />
                                                            </Border>
                                                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Name}"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                           FontSize="18"
                                                                           FontWeight="SemiBold" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding Category}"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           FontSize="13"
                                                                           FontWeight="SemiBold" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding DurationText}"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontSize="18"
                                                                       FontWeight="Bold"
                                                                       HorizontalAlignment="Right" />
                                                            <TextBlock Margin="0,4,0,0"
                                                                       Text="{Binding SharePercentText}"
                                                                       Foreground="{Binding AccentBrush}"
                                                                       FontSize="14"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Right" />
                                                        </StackPanel>
                                                    </Grid>
                                                    <Grid Grid.Row="1" Margin="0,18,0,0">
                                                        <Border Height="10"
                                                                CornerRadius="5"
                                                                Background="#173042" />
                                                        <Border Height="10"
                                                                CornerRadius="5"
                                                                Background="{Binding AccentBrush}"
                                                                HorizontalAlignment="Stretch"
                                                                RenderTransformOrigin="0,0.5">
                                                            <Border.RenderTransform>
                                                                <ScaleTransform ScaleX="{Binding ShareOfTotal}" />
                                                            </Border.RenderTransform>
                                                        </Border>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="SettingsGrid" Visibility="{Binding SettingsVisibility}">
                        <Border x:Name="SettingsCard" Style="{StaticResource CardStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Access rules" Foreground="{StaticResource TextPrimaryBrush}" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Margin="0,8,0,0" Text="Allowed = time-limited access. Blocked = always denied. Apps and sites not listed here are allowed without any limit." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />

                                 <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                     <Button Content="Add app"
                                             Style="{StaticResource RoundedActionButtonStyle}"
                                             Width="120" Margin="0,0,12,0"
                                             Click="OnAddAppClick" />
                                     <Button Content="Add website"
                                             Style="{StaticResource RoundedActionButtonStyle}"
                                             Width="120" Margin="0,0,12,0"
                                             Click="OnAddWebsiteClick" />
                                 </StackPanel>

                                <TextBlock Text="&#x2714;  Allowed (time-limited)" Foreground="{StaticResource AccentBrush}" FontSize="18" FontWeight="SemiBold" Margin="0,22,0,12" />
                                <ItemsControl ItemsSource="{Binding AllowedRules}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type local:BlockRule}">
                                            <Border Margin="0,0,0,10" Style="{StaticResource ListCardStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" />
                                                            <Border Margin="8,0,0,0" Padding="8,3" Background="#173040" CornerRadius="10">
                                                                <TextBlock Text="{Binding TargetType}" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="SemiBold" />
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="Limit" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                        <Border Background="#14FFFFFF" BorderBrush="#24FFFFFF" BorderThickness="1" CornerRadius="14">
                                                            <TextBox Width="56" Text="{Binding MaxMinutes, UpdateSourceTrigger=PropertyChanged}"
                                                                     Style="{StaticResource GlassTextBoxStyle}"
                                                                     HorizontalContentAlignment="Center" />
                                                        </Border>
                                                        <TextBlock Text="min" Foreground="{StaticResource TextSecondaryBrush}" Margin="6,0,0,0" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                                                        <Button Content="Block" Click="OnMoveToBlockedClick" Tag="{Binding}"
                                                                Style="{StaticResource GlassSmallButtonStyle}"
                                                                Width="56" Height="28" FontSize="12" FontWeight="SemiBold"
                                                                Foreground="#FF7D66" VerticalAlignment="Center" ToolTip="Move to blocked list" />
                                                        <Button Content="&#x2715;" Click="OnDeleteRuleClick" Tag="{Binding}"
                                                                Style="{StaticResource GlassSmallButtonStyle}"
                                                                Width="28" Height="28" FontSize="12"
                                                                Foreground="#666" VerticalAlignment="Center" Margin="4,0,0,0" ToolTip="Delete" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="&#x2716;  Blocked (always denied)" Foreground="{StaticResource AccentCoralBrush}" FontSize="18" FontWeight="SemiBold" Margin="0,18,0,12" />
                                <ItemsControl ItemsSource="{Binding BlockedRules}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type local:BlockRule}">
                                            <Border Margin="0,0,0,10" Style="{StaticResource ListCardStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" />
                                                            <Border Margin="8,0,0,0" Padding="8,3" Background="#173040" CornerRadius="10">
                                                                <TextBlock Text="{Binding TargetType}" Foreground="{StaticResource AccentCoralBrush}" FontSize="11" FontWeight="SemiBold" />
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Button Content="Allow" Click="OnMoveToAllowedClick" Tag="{Binding}"
                                                                Style="{StaticResource GlassSmallButtonStyle}"
                                                                Width="56" Height="28" FontSize="12" FontWeight="SemiBold"
                                                                Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" ToolTip="Move to allowed list" />
                                                        <Button Content="&#x2715;" Click="OnDeleteRuleClick" Tag="{Binding}"
                                                                Style="{StaticResource GlassSmallButtonStyle}"
                                                                Width="28" Height="28" FontSize="12"
                                                                Foreground="#666" VerticalAlignment="Center" Margin="4,0,0,0" ToolTip="Delete" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Content="Save settings"
                                        Style="{StaticResource RoundedActionButtonStyle}"
                                        Width="140" Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Click="OnSaveSettingsClick" />

                                <Separator Margin="0,24,0,0" Background="{StaticResource BorderBrushStrong}" />

                                <TextBlock Text="Danger zone" Foreground="{StaticResource AccentCoralBrush}" FontSize="20" FontWeight="SemiBold" Margin="0,18,0,8" />
                                <TextBlock Text="Resetting removes all access rules. Use this if you want to clear the configuration and start over." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />
                                <Button Content="Reset all settings"
                                        Style="{StaticResource RoundedActionButtonStyle}"
                                        Background="{StaticResource DangerButtonBrush}"
                                        Width="160" Margin="0,0,0,0"
                                        HorizontalAlignment="Left"
                                        Click="OnResetAllSettingsClick" />
                            </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <Border x:Name="BlockPopupHost"
                    Visibility="{Binding BlockPopupVisibility}"
                    Opacity="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,28,28"
                    Padding="16,12"
                    Background="#B0162434"
                    BorderBrush="#7AFFB39F"
                    BorderThickness="1"
                    CornerRadius="20"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="0.92" ScaleY="0.92" />
                        <TranslateTransform Y="14" />
                    </TransformGroup>
                </Border.RenderTransform>
                <TextBlock Text="{Binding BlockPopupMessage}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="14"
                           FontWeight="SemiBold" />
            </Border>

            <Grid x:Name="InputPopupOverlay"
                  Visibility="Collapsed">
                <Border Background="#8A050B11" />
                <Border Width="400" Height="240"
                        Background="{StaticResource CardBrush}"
                        BorderBrush="#36FFFFFF"
                        BorderThickness="1"
                        CornerRadius="28"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel Margin="32">
                        <TextBlock x:Name="PopupTitle"
                                   Text="Add Rule"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,16" />
                        <TextBlock x:Name="PopupInstruction"
                                   Text="Please enter the name."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,24" />
                        <Border Style="{StaticResource GlassInputBorderStyle}" Width="336" Margin="0,0,0,24">
                            <TextBox x:Name="PopupInput"
                                     Style="{StaticResource GlassTextBoxStyle}" />
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel"
                                    Style="{StaticResource NavButtonStyle}"
                                    Background="Transparent"
                                    Width="100"
                                    Margin="0,0,12,0"
                                    Click="OnPopupCancelClick" />
                            <Button Content="Add"
                                    Style="{StaticResource RoundedActionButtonStyle}"
                                    Width="100"
                                    Click="OnPopupAddClick" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="PinPopupOverlay"
                  Visibility="Collapsed">
                <Border Background="#8A050B11" />
                <Border Width="380" Height="260"
                        Background="{StaticResource CardBrush}"
                        BorderBrush="#4E71E4C3"
                        BorderThickness="1"
                        CornerRadius="28"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel Margin="32">
                        <TextBlock Text="&#x1F512;  Enter PIN"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <TextBlock x:Name="PinInstruction"
                                   Text="PIN required to access settings."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,20" />
                        <Border Style="{StaticResource GlassInputBorderStyle}" Margin="0,0,0,8">
                            <PasswordBox x:Name="PinInput"
                                         Style="{StaticResource GlassPasswordBoxStyle}"
                                         HorizontalContentAlignment="Center"
                                         MaxLength="4"
                                         PasswordChar="*" />
                        </Border>
                        <TextBlock x:Name="PinError"
                                   Text="Incorrect PIN. Try again."
                                   Foreground="{StaticResource AccentCoralBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,16"
                                   Visibility="Collapsed" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Button Content="Cancel"
                                    Style="{StaticResource NavButtonStyle}"
                                    Background="Transparent"
                                    Width="100"
                                    Margin="0,0,12,0"
                                    Click="OnPinCancelClick" />
                            <Button Content="Unlock"
                                    Style="{StaticResource RoundedActionButtonStyle}"
                                    Width="100"
                                    Click="OnPinSubmitClick" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="ResetConfirmOverlay"
                  Visibility="Collapsed">
                <Border Background="#8A050B11" />
                <Border Width="400" Height="200"
                        Background="{StaticResource CardBrush}"
                        BorderBrush="#5EFF8A72"
                        BorderThickness="1"
                        CornerRadius="28"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel Margin="32">
                        <TextBlock Text="Reset all settings?"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="This will delete all access rules and restore the defaults. Any sites currently being blocked by these rules will be unblocked."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,20" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel"
                                    Style="{StaticResource NavButtonStyle}"
                                    Background="Transparent"
                                    Width="100"
                                    Margin="0,0,12,0"
                                    Click="OnResetCancelClick" />
                            <Button Content="Reset"
                                    Style="{StaticResource RoundedActionButtonStyle}"
                                    Background="{StaticResource DangerButtonBrush}"
                                    Width="100"
                                    Click="OnResetConfirmClick" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
    </Border>
</Window>
