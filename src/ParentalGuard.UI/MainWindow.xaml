<Window x:Class="ParentalGuard.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ParentalGuard.UI"
        mc:Ignorable="d"
        Title="ParentalGuard"
        Width="1260"
        Height="840"
        MinWidth="1020"
        MinHeight="720"
        Background="#01000000"
        FontFamily="Bahnschrift"
        Loaded="OnWindowLoaded"
        StateChanged="OnWindowStateChanged"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="38"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="-1"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <SolidColorBrush x:Key="PageBrush" Color="#550A1118" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#660E1822" />
        <SolidColorBrush x:Key="CardBrush" Color="#55111C27" />
        <SolidColorBrush x:Key="BorderBrushStrong" Color="#213547" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F5F7FA" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9CB0C4" />
        <SolidColorBrush x:Key="AccentBrush" Color="#3FD0AE" />
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#6BB8FF" />
        <SolidColorBrush x:Key="AccentCoralBrush" Color="#FF7D66" />

        <DropShadowEffect x:Key="CardShadow" BlurRadius="24" ShadowDepth="0" Opacity="0.2" Color="#000000" />
        <CubicEase x:Key="EaseOutCubic" EasingMode="EaseOut" />
        <QuadraticEase x:Key="EaseOutQuad" EasingMode="EaseOut" />
        <BackEase x:Key="EaseOutBack" EasingMode="EaseOut" Amplitude="0.5" />
        <CubicEase x:Key="EaseInOutCubic" EasingMode="EaseInOut" />
        <PowerEase x:Key="EaseOutPower" EasingMode="EaseOut" Power="3" />

        <LinearGradientBrush x:Key="GlassOverlayBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#14FFFFFF" Offset="0" />
            <GradientStop Color="#06FFFFFF" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GlassOverlayStrongBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#26FFFFFF" Offset="0" />
            <GradientStop Color="#0AFFFFFF" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GlassHighlightBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#1AFFFFFF" Offset="0" />
            <GradientStop Color="#00FFFFFF" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Effect" Value="{StaticResource CardShadow}" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="28" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ListCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                        <TranslateTransform Y="0" />
                    </TransformGroup>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#35516A" />
                </Trigger>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                             To="1.015"
                                             Duration="0:0:0.24"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                             To="1.015"
                                             Duration="0:0:0.24"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                             To="-4"
                                             Duration="0:0:0.24"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                             To="1"
                                             Duration="0:0:0.22"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                             To="1"
                                             Duration="0:0:0.22"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                             To="0"
                                             Duration="0:0:0.22"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="NavButtonChrome" Background="{TemplateBinding Background}" CornerRadius="14" />
                            <Border x:Name="GlassBorder" CornerRadius="14"
                                    BorderBrush="#1AFFFFFF" BorderThickness="1"
                                    Background="{StaticResource GlassOverlayBrush}" />
                             <Rectangle x:Name="Shine" RadiusX="12" RadiusY="12"
                                        VerticalAlignment="Top" Height="16" Margin="1"
                                        Fill="{StaticResource GlassHighlightBrush}" />
                             <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                         </Grid>
                         <ControlTemplate.Triggers>
                             <Trigger Property="IsMouseOver" Value="True">
                                 <Setter TargetName="NavButtonChrome" Property="Background" Value="#153244" />
                                <Setter TargetName="GlassBorder" Property="BorderBrush" Value="#30FFFFFF" />
                                <Setter TargetName="GlassBorder" Property="Background" Value="{StaticResource GlassOverlayStrongBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NavButtonChrome" Property="Background" Value="#1E4157" />
                                <Setter TargetName="GlassBorder" Property="BorderBrush" Value="#18FFFFFF" />
                                <Setter TargetName="GlassBorder" Property="Background" Value="{StaticResource GlassOverlayBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1.03"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1.03"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RoundedActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentCoralBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="ActionButtonChrome" Background="{TemplateBinding Background}" CornerRadius="14" />
                            <Border x:Name="GlassBorder" CornerRadius="14"
                                    BorderBrush="#2AFFFFFF" BorderThickness="1"
                                    Background="{StaticResource GlassOverlayStrongBrush}" />
                             <Rectangle x:Name="Shine" RadiusX="12" RadiusY="12"
                                        VerticalAlignment="Top" Height="16" Margin="1"
                                        Fill="{StaticResource GlassHighlightBrush}" />
                             <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                         </Grid>
                         <ControlTemplate.Triggers>
                             <Trigger Property="IsMouseOver" Value="True">
                                 <Setter TargetName="ActionButtonChrome" Property="Background" Value="#FF8C77" />
                                <Setter TargetName="GlassBorder" Property="BorderBrush" Value="#3CFFFFFF" />
                                <Setter TargetName="GlassBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#32FFFFFF" Offset="0" />
                                            <GradientStop Color="#12FFFFFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ActionButtonChrome" Property="Background" Value="#FF6B54" />
                                <Setter TargetName="GlassBorder" Property="BorderBrush" Value="#20FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1.04"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1.04"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1"
                                             Duration="0:0:0.18"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RoundedToggleCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="64" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <Border x:Name="Track"
                                    Background="#142533"
                                    BorderBrush="{StaticResource BorderBrushStrong}"
                                    BorderThickness="1"
                                    CornerRadius="17" />
                            <Border x:Name="Glow"
                                    Margin="4"
                                    Background="#00000000"
                                    CornerRadius="14" />
                            <Ellipse x:Name="Thumb"
                                     Width="24"
                                     Height="24"
                                     Margin="5,0,0,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Fill="#F5F7FA"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                        <TranslateTransform X="0" />
                                    </TransformGroup>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <TextBlock x:Name="ToggleText"
                                       Text="Off"
                                       Margin="0,0,10,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#173F3A" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="#33A991" />
                                <Setter TargetName="Glow" Property="Background" Value="#153A34" />
                                <Setter TargetName="ToggleText" Property="Text" Value="On" />
                                <Setter TargetName="ToggleText" Property="Foreground" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ToggleText" Property="HorizontalAlignment" Value="Left" />
                                <Setter TargetName="ToggleText" Property="Margin" Value="10,0,0,0" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="#3A5F77" />
                            </Trigger>
                            <EventTrigger RoutedEvent="Checked">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.X)"
                                                         To="30"
                                                         Duration="0:0:0.22"
                                                         EasingFunction="{StaticResource EaseOutCubic}" />
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                         From="0.92"
                                                         To="1"
                                                         Duration="0:0:0.22"
                                                         EasingFunction="{StaticResource EaseOutCubic}" />
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                         From="0.92"
                                                         To="1"
                                                         Duration="0:0:0.22"
                                                         EasingFunction="{StaticResource EaseOutCubic}" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Unchecked">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.X)"
                                                         To="0"
                                                         Duration="0:0:0.22"
                                                         EasingFunction="{StaticResource EaseOutCubic}" />
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                         From="0.92"
                                                         To="1"
                                                         Duration="0:0:0.22"
                                                         EasingFunction="{StaticResource EaseOutCubic}" />
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                         From="0.92"
                                                         To="1"
                                                         Duration="0:0:0.22"
                                                         EasingFunction="{StaticResource EaseOutCubic}" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GlassSmallButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" CornerRadius="8"
                                BorderBrush="#18FFFFFF" BorderThickness="1"
                                Background="#14FFFFFF">
                            <Grid>
                                <Rectangle x:Name="Shine" RadiusX="7" RadiusY="7"
                                           VerticalAlignment="Top" Height="12" Margin="1"
                                           Fill="{StaticResource GlassHighlightBrush}" />
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#24FFFFFF" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#30FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#10FFFFFF" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#14FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1.06" Duration="0:0:0.14"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1.06" Duration="0:0:0.14"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1" Duration="0:0:0.14"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1" Duration="0:0:0.14"
                                             EasingFunction="{StaticResource EaseOutQuad}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AnimatedTitleBarButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" CornerRadius="6"
                                BorderBrush="#0CFFFFFF" BorderThickness="1"
                                Background="#0AFFFFFF">
                            <Grid>
                                <Rectangle x:Name="Shine" RadiusX="5" RadiusY="5"
                                           VerticalAlignment="Top" Height="12" Margin="1"
                                           Fill="{StaticResource GlassHighlightBrush}" />
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,1" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#1CFFFFFF" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#28FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#10FFFFFF" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#14FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1.12" Duration="0:0:0.22"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1.12" Duration="0:0:0.22"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1" Duration="0:0:0.3"
                                             EasingFunction="{StaticResource EaseOutBack}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1" Duration="0:0:0.3"
                                             EasingFunction="{StaticResource EaseOutBack}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AnimatedCloseButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Chrome" CornerRadius="6"
                                    BorderBrush="#0CFFFFFF" BorderThickness="1"
                                    Background="#0AFFFFFF" />
                            <Border x:Name="HoverBg" CornerRadius="6"
                                    Background="#00FF7D66" />
                            <Border x:Name="GlowBorder" CornerRadius="6"
                                    BorderBrush="#00FF7D66" BorderThickness="1" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,1" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverBg" Property="Background" Value="#1AFF7D66" />
                                <Setter TargetName="GlowBorder" Property="BorderBrush" Value="#30FF7D66" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HoverBg" Property="Background" Value="#28FF7D66" />
                                <Setter TargetName="GlowBorder" Property="BorderBrush" Value="#18FF7D66" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1.14" Duration="0:0:0.22"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1.14" Duration="0:0:0.22"
                                             EasingFunction="{StaticResource EaseOutCubic}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1" Duration="0:0:0.3"
                                             EasingFunction="{StaticResource EaseOutBack}" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1" Duration="0:0:0.3"
                                             EasingFunction="{StaticResource EaseOutBack}" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="0" Margin="0"
            Background="{StaticResource PageBrush}" BorderBrush="#1A2B3B" BorderThickness="0">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.ColumnSpan="2" x:Name="TopBar" Background="#0C1218"
                BorderBrush="Transparent" BorderThickness="0">
            <Grid>
                <Border x:Name="TopBarShimmer" Opacity="0" IsHitTestVisible="False">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop x:Name="ShimmerStop1" Color="#083FD0AE" Offset="0" />
                            <GradientStop x:Name="ShimmerStop2" Color="#003FD0AE" Offset="0.35" />
                            <GradientStop x:Name="ShimmerStop3" Color="#086BB8FF" Offset="0.65" />
                            <GradientStop x:Name="ShimmerStop4" Color="#006BB8FF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <Rectangle x:Name="TopBarAccentLine" VerticalAlignment="Bottom" Height="1"
                           Opacity="0" IsHitTestVisible="False">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#003FD0AE" Offset="0" />
                            <GradientStop Color="#3FD0AE" Offset="0.3" />
                            <GradientStop Color="#6BB8FF" Offset="0.5" />
                            <GradientStop Color="#3FD0AE" Offset="0.7" />
                            <GradientStop Color="#003FD0AE" Offset="1" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <Border x:Name="TopBarLogo" Width="22" Height="22" CornerRadius="6"
                                Background="#173040" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="0" ScaleY="0" />
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect x:Name="LogoGlow" Color="#3FD0AE"
                                                  BlurRadius="14" ShadowDepth="0" Opacity="0" />
                            </Border.Effect>
                            <Path Data="M12,6 L28,6 L28,16 C28,22 24,28 20,30 C16,28 12,22 12,16 Z"
                                  Fill="{StaticResource AccentBrush}" Stretch="Fill" Margin="4" />
                        </Border>

                        <TextBlock x:Name="TopBarTitleText" Text="ParentalGuard"
                                   Foreground="#9CB0C4" FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                   Opacity="0" RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <TranslateTransform X="-10" />
                            </TextBlock.RenderTransform>
                        </TextBlock>

                        <Grid Margin="8,0,0,0" VerticalAlignment="Center"
                              Width="10" Height="10">
                            <Ellipse x:Name="StatusDotGlow" Width="10" Height="10"
                                     Fill="#3FD0AE" Opacity="0.2"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse x:Name="StatusDot" Width="5" Height="5"
                                     Fill="{StaticResource AccentBrush}" Opacity="0.85"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,4,0">
                        <Button Content="&#x2013;" Click="OnMinimizeClick"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Style="{StaticResource AnimatedTitleBarButtonStyle}"
                                Width="38" Height="28" FontSize="14" FontWeight="Normal"
                                Foreground="#9CB0C4" />
                        <Button Content="&#x25A1;" Click="OnMaximizeClick"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Style="{StaticResource AnimatedTitleBarButtonStyle}"
                                Width="38" Height="28" FontSize="11" FontWeight="Normal"
                                Foreground="#9CB0C4" />
                        <Button Content="&#x2715;" Click="OnCloseClick"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Style="{StaticResource AnimatedCloseButtonStyle}"
                                Width="38" Height="28" FontSize="12" FontWeight="Normal"
                                Foreground="#FF7D66" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="SidebarBorder" Grid.Row="1" Background="{StaticResource SidebarBrush}" BorderBrush="#1A2B3B" BorderThickness="0,0,1,0" Padding="18">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,6">
                    <Border Width="40" Height="40" CornerRadius="12" Background="#173040" Margin="0,0,12,0">
                        <Grid>
                            <Path Data="M12,6 L28,6 L28,16 C28,22 24,28 20,30 C16,28 12,22 12,16 Z" Fill="{StaticResource AccentBrush}" Stretch="Fill" Margin="8" />
                        </Grid>
                    </Border>
                    <TextBlock Text="ParentalGuard" Foreground="{StaticResource TextPrimaryBrush}" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="Live app and website usage" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,24" />

                <Button Style="{StaticResource NavButtonStyle}" Background="{Binding OverviewButtonBrush}" Content="Overview" Click="OnOverviewClick" />
                <Button Style="{StaticResource NavButtonStyle}" Background="{Binding UsageButtonBrush}" Margin="0,8,0,0" Content="Usage" Click="OnUsageClick" />
                <Button Style="{StaticResource NavButtonStyle}" Background="{Binding SettingsButtonBrush}" Margin="0,8,0,0" Content="Settings" Click="OnSettingsClick" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Grid.Column="1">
            <Canvas IsHitTestVisible="False">
                <Ellipse Width="360" Height="360" Canvas.Left="-120" Canvas.Top="-90" Opacity="0.28">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#214666" Offset="0" />
                            <GradientStop Color="#00000000" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
            </Canvas>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="28">
                    <Border x:Name="HeaderCard" Style="{StaticResource CardStyle}" Margin="0,0,0,22">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding PageTitle}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="34" FontWeight="SemiBold" />
                            <Border Grid.Column="1" Padding="16,10" Background="#132532" CornerRadius="14" VerticalAlignment="Top">
                                <TextBlock Text="{Binding CurrentClockText}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                    </Border>

                    <Grid x:Name="OverviewGrid" Visibility="{Binding OverviewVisibility}">
                        <Border x:Name="GraphCard" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Screen time line graph" Foreground="{StaticResource TextPrimaryBrush}" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Margin="0,8,0,0" Text="Stored in the local database and updated over time." Foreground="{StaticResource TextSecondaryBrush}" />

                                <Grid Margin="0,24,0,0">
                                    <Canvas Height="220">
                                        <Path Stroke="{StaticResource AccentBlueBrush}" StrokeThickness="3" Data="{Binding UsageLineGeometry}" />
                                        <ItemsControl ItemsSource="{Binding DailyUsageGraph}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type local:LineGraphPoint}">
                                                    <Grid>
                                                        <Ellipse Width="12" Height="12" Fill="{StaticResource AccentBrush}" />
                                                        <TextBlock Margin="-18,-28,0,0" Text="{Binding DurationText}" Foreground="{StaticResource TextSecondaryBrush}" />
                                                        <TextBlock Margin="-8,18,0,0" Text="{Binding Label}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Canvas>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="UsageGrid" Visibility="{Binding UsageVisibility}">
                        <Border x:Name="UsageCombinedCard" Style="{StaticResource CardStyle}" Margin="0,0,0,22">
                            <StackPanel>
                                <TextBlock Text="Usage" Foreground="{StaticResource TextPrimaryBrush}" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Margin="0,8,0,0" Text="All apps and website domains in one list. Each website domain is its own item." Foreground="{StaticResource TextSecondaryBrush}" />

                                <ItemsControl Margin="0,18,0,0" ItemsSource="{Binding AllUsage}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type local:UsageEntry}">
                                            <Border Margin="0,0,0,12" Style="{StaticResource ListCardStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Ellipse Width="10" Height="10" Fill="{Binding AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
                                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="SemiBold" />
                                                        </StackPanel>
                                                        <TextBlock Margin="0,8,0,0" Text="{Binding Subtitle}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Margin="16,0,0,0" Text="{Binding DurationText}" Foreground="{Binding AccentBrush}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="SettingsGrid" Visibility="{Binding SettingsVisibility}">
                        <Border x:Name="SettingsCard" Style="{StaticResource CardStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Access rules" Foreground="{StaticResource TextPrimaryBrush}" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Margin="0,8,0,0" Text="Allowed = time-limited access. Blocked = always denied. Apps and sites not listed here are allowed without any limit." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />

                                 <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                     <Button Content="Add app"
                                             Style="{StaticResource RoundedActionButtonStyle}"
                                             Width="120" Margin="0,0,12,0"
                                             Click="OnAddAppClick" />
                                     <Button Content="Add website"
                                             Style="{StaticResource RoundedActionButtonStyle}"
                                             Width="120" Margin="0,0,12,0"
                                             Click="OnAddWebsiteClick" />
                                 </StackPanel>

                                <TextBlock Text="&#x2714;  Allowed (time-limited)" Foreground="{StaticResource AccentBrush}" FontSize="18" FontWeight="SemiBold" Margin="0,22,0,12" />
                                <ItemsControl ItemsSource="{Binding AllowedRules}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type local:BlockRule}">
                                            <Border Margin="0,0,0,10" Style="{StaticResource ListCardStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" />
                                                            <Border Margin="8,0,0,0" Padding="8,3" Background="#173040" CornerRadius="10">
                                                                <TextBlock Text="{Binding TargetType}" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="SemiBold" />
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="Limit" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                        <Border Background="#132532" BorderBrush="{StaticResource BorderBrushStrong}" BorderThickness="1" CornerRadius="12">
                                                            <TextBox Width="56" Text="{Binding MaxMinutes, UpdateSourceTrigger=PropertyChanged}"
                                                                     Padding="10,6" Background="Transparent"
                                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                                     BorderThickness="0" HorizontalContentAlignment="Center" />
                                                        </Border>
                                                        <TextBlock Text="min" Foreground="{StaticResource TextSecondaryBrush}" Margin="6,0,0,0" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                                                        <Button Content="Block" Click="OnMoveToBlockedClick" Tag="{Binding}"
                                                                Style="{StaticResource GlassSmallButtonStyle}"
                                                                Width="56" Height="28" FontSize="12" FontWeight="SemiBold"
                                                                Foreground="#FF7D66" VerticalAlignment="Center" ToolTip="Move to blocked list" />
                                                        <Button Content="&#x2715;" Click="OnDeleteRuleClick" Tag="{Binding}"
                                                                Style="{StaticResource GlassSmallButtonStyle}"
                                                                Width="28" Height="28" FontSize="12"
                                                                Foreground="#666" VerticalAlignment="Center" Margin="4,0,0,0" ToolTip="Delete" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="&#x2716;  Blocked (always denied)" Foreground="{StaticResource AccentCoralBrush}" FontSize="18" FontWeight="SemiBold" Margin="0,18,0,12" />
                                <ItemsControl ItemsSource="{Binding BlockedRules}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type local:BlockRule}">
                                            <Border Margin="0,0,0,10" Style="{StaticResource ListCardStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" />
                                                            <Border Margin="8,0,0,0" Padding="8,3" Background="#173040" CornerRadius="10">
                                                                <TextBlock Text="{Binding TargetType}" Foreground="{StaticResource AccentCoralBrush}" FontSize="11" FontWeight="SemiBold" />
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Button Content="Allow" Click="OnMoveToAllowedClick" Tag="{Binding}"
                                                                Style="{StaticResource GlassSmallButtonStyle}"
                                                                Width="56" Height="28" FontSize="12" FontWeight="SemiBold"
                                                                Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" ToolTip="Move to allowed list" />
                                                        <Button Content="&#x2715;" Click="OnDeleteRuleClick" Tag="{Binding}"
                                                                Style="{StaticResource GlassSmallButtonStyle}"
                                                                Width="28" Height="28" FontSize="12"
                                                                Foreground="#666" VerticalAlignment="Center" Margin="4,0,0,0" ToolTip="Delete" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Content="Save settings"
                                        Style="{StaticResource RoundedActionButtonStyle}"
                                        Width="140" Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Click="OnSaveSettingsClick" />

                                <Separator Margin="0,24,0,0" Background="{StaticResource BorderBrushStrong}" />

                                <TextBlock Text="Danger zone" Foreground="{StaticResource AccentCoralBrush}" FontSize="20" FontWeight="SemiBold" Margin="0,18,0,8" />
                                <TextBlock Text="Resetting removes all access rules and restores defaults. This fixes issues where legitimate sites are being blocked unexpectedly." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />
                                <Button Content="Reset all settings"
                                        Style="{StaticResource RoundedActionButtonStyle}"
                                        Width="160" Margin="0,0,0,0"
                                        HorizontalAlignment="Left"
                                        Click="OnResetAllSettingsClick" />
                            </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <Border x:Name="BlockPopupHost"
                    Visibility="{Binding BlockPopupVisibility}"
                    Opacity="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,28,28"
                    Padding="16,12"
                    Background="#162734"
                    BorderBrush="{StaticResource AccentCoralBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="0.92" ScaleY="0.92" />
                        <TranslateTransform Y="14" />
                    </TransformGroup>
                </Border.RenderTransform>
                <TextBlock Text="{Binding BlockPopupMessage}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="14"
                           FontWeight="SemiBold" />
            </Border>

            <Grid x:Name="InputPopupOverlay"
                  Visibility="Collapsed">
                <Border Background="#AA000000" />
                <Border Width="400" Height="240"
                        Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource BorderBrushStrong}"
                        BorderThickness="1"
                        CornerRadius="22"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel Margin="32">
                        <TextBlock x:Name="PopupTitle"
                                   Text="Add Rule"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,16" />
                        <TextBlock x:Name="PopupInstruction"
                                   Text="Please enter the name."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,24" />
                        <Border BorderBrush="{StaticResource BorderBrushStrong}" BorderThickness="1" CornerRadius="8" Width="336" Margin="0,0,0,24">
                            <TextBox x:Name="PopupInput"
                                     Padding="12,8"
                                     Background="#132532"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderThickness="0"
                                     FontSize="16" />
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel"
                                    Style="{StaticResource NavButtonStyle}"
                                    Background="Transparent"
                                    Width="100"
                                    Margin="0,0,12,0"
                                    Click="OnPopupCancelClick" />
                            <Button Content="Add"
                                    Style="{StaticResource RoundedActionButtonStyle}"
                                    Width="100"
                                    Click="OnPopupAddClick" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="PinPopupOverlay"
                  Visibility="Collapsed">
                <Border Background="#AA000000" />
                <Border Width="380" Height="260"
                        Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1"
                        CornerRadius="22"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel Margin="32">
                        <TextBlock Text="&#x1F512;  Enter PIN"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <TextBlock x:Name="PinInstruction"
                                   Text="PIN required to access settings."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,20" />
                        <Border BorderBrush="{StaticResource BorderBrushStrong}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,8">
                            <PasswordBox x:Name="PinInput"
                                         Padding="12,8"
                                         Background="#132532"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         BorderThickness="0"
                                         FontSize="20"
                                         HorizontalContentAlignment="Center"
                                         MaxLength="4"
                                         PasswordChar="*" />
                        </Border>
                        <TextBlock x:Name="PinError"
                                   Text="Incorrect PIN. Try again."
                                   Foreground="{StaticResource AccentCoralBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,16"
                                   Visibility="Collapsed" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Button Content="Cancel"
                                    Style="{StaticResource NavButtonStyle}"
                                    Background="Transparent"
                                    Width="100"
                                    Margin="0,0,12,0"
                                    Click="OnPinCancelClick" />
                            <Button Content="Unlock"
                                    Style="{StaticResource RoundedActionButtonStyle}"
                                    Width="100"
                                    Click="OnPinSubmitClick" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="ResetConfirmOverlay"
                  Visibility="Collapsed">
                <Border Background="#AA000000" />
                <Border Width="400" Height="200"
                        Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource AccentCoralBrush}"
                        BorderThickness="1"
                        CornerRadius="22"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel Margin="32">
                        <TextBlock Text="Reset all settings?"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="This will delete all access rules and restore the defaults. Any sites currently being blocked by these rules will be unblocked."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,20" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel"
                                    Style="{StaticResource NavButtonStyle}"
                                    Background="Transparent"
                                    Width="100"
                                    Margin="0,0,12,0"
                                    Click="OnResetCancelClick" />
                            <Button Content="Reset"
                                    Style="{StaticResource RoundedActionButtonStyle}"
                                    Width="100"
                                    Click="OnResetConfirmClick" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
    </Border>
</Window>
